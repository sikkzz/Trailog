{
  "name": "trailog",
  "version": "0.0.0",
  "private": true,
  "description": "여행 사진 지도 아카이브 모바일 앱",
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20.14.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "db:up": "docker compose -f docker/compose.yml up -d",
    "db:down": "docker compose -f docker/compose.yml down",
    "db:logs": "docker compose -f docker/compose.yml logs -f",
    "db:psql": "docker compose -f docker/compose.yml exec postgres psql -U trailog -d trailog",
    "db:redis": "docker compose -f docker/compose.yml exec redis redis-cli",
    "db:reset": "docker compose -f docker/compose.yml down -v"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
