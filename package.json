{
  "name": "trailog",
  "version": "0.0.0",
  "private": true,
  "description": "여행 사진 지도 아카이브 모바일 앱",
  "packageManager": "pnpm@9.9.0",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yaml,yml}\"",
    "db:up": "docker compose -f docker/compose.yml up -d",
    "db:down": "docker compose -f docker/compose.yml down",
    "db:logs": "docker compose -f docker/compose.yml logs -f",
    "db:psql": "docker compose -f docker/compose.yml exec postgres psql -U trailog -d trailog",
    "db:redis": "docker compose -f docker/compose.yml exec redis redis-cli",
    "db:reset": "docker compose -f docker/compose.yml down -v",
    "sync:notion": "node scripts/sync-to-notion.mjs",
    "sync:notion:dry": "node scripts/sync-to-notion.mjs --dry-run"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@notionhq/client": "^5.22.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "//lint-staged": "룰은 .lintstagedrc.cjs로 분리 — ESLint v9 flat config가 workspace cwd 필요해서 함수형 룰 사용 (root config 없으면 cwd 못 찾음)"
}
