# Trailog pnpm 설정
#
# node-linker=hoisted:
# - pnpm의 엄격한 비호이스팅 정책을 끄고 npm/yarn처럼 모든 의존성을
#   루트 node_modules로 끌어올림 (호이스팅).
# - 이유: Expo + React Native가 transitive 의존성을 자유롭게 require하는
#   패턴을 사용하는데, pnpm 기본 동작과 충돌하기 때문.
#   대표 에러: "Unable to resolve @expo/log-box/src/LogBox"
# - Trade-off: 유령 의존성(phantom dependency) 방지 효과는 잃지만,
#   Expo 공식 monorepo 가이드의 권장 설정.
#   대안인 public-hoist-pattern은 트랜지티브 deps가 늘면 관리 부담 큼.
# 참고: https://docs.expo.dev/guides/monorepos/
node-linker=hoisted

# strict-peer-dependencies=false:
# - peer dep 미충족 시 경고만 띄우고 install 계속.
# - RN 생태계가 peer 충족 안 된 패키지를 자주 publish해서 필요.
strict-peer-dependencies=false

# auto-install-peers=true:
# - peer dep 자동 설치 (pnpm 8+ 기본값이지만 명시).
auto-install-peers=true
