# apps/mobile .env.example
#
# Expo/RN 환경변수 가이드. cp .env.example .env 후 본인 값으로.
# 주: Expo는 `EXPO_PUBLIC_` prefix 키만 클라이언트 번들에 노출 (build time inline).
#     비밀 키는 절대 EXPO_PUBLIC_ prefix로 두지 말 것 (클라이언트에 그대로 박힘).
#
# 참조 프론트 비교 (Next.js): `NEXT_PUBLIC_*`도 동일 패턴 (build time inline + 클라 노출).
# 같은 사고 — secret은 prefix 없이 두면 서버 측만 접근.

# ─── 백엔드 API 연결 (Phase 2 4.1~) ───

# 백엔드 base URL — apiRequest가 prefix로 사용.
# - 시뮬레이터: http://localhost:3000
# - 실기기 + 같은 Wi-Fi: http://<Mac LAN IP>:3000 (예: http://192.168.0.10:3000)
# - 실기기 + tunnel(ngrok): tunnel URL
# - 운영: https://trailog-server.fly.dev
EXPO_PUBLIC_API_URL=http://localhost:3000
