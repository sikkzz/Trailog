{
  "name": "@trailog/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "Trailog 모바일 앱 (React Native + Expo)",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:clear": "expo start --clear",
    "dev:tunnel": "expo start --tunnel",
    "dev:lan": "expo start --host lan",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build": "echo 'mobile build via EAS — use pnpm build:dev:ios 등'",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
    "eas:device": "eas device:create",
    "eas:login": "eas login",
    "eas:whoami": "eas whoami",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "echo 'test TBD'"
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.15",
    "@hookform/resolvers": "^5.4.0",
    "@mj-studio/react-native-naver-map": "^2.9.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@tanstack/react-query": "^5.101.0",
    "expo": "^56.0.11",
    "expo-build-properties": "~56.0.18",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "^56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "^56.0.8",
    "expo-font": "~56.0.6",
    "expo-image": "^56.0.11",
    "expo-image-picker": "^56.0.17",
    "expo-linking": "^56.0.14",
    "expo-location": "~56.0.17",
    "expo-router": "^56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "^56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "nativewind": "^4.2.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.77.0",
    "react-native": "^0.85.3",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-sse": "^1.2.1",
    "react-native-web": "^0.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@trailog/eslint-config": "workspace:^",
    "@types/react": "^19.2.15",
    "eslint": "^9.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  }
}
