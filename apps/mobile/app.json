{
  "expo": {
    "name": "Trailog",
    "slug": "trailog",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "trailog",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.trailog.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.trailog.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a7aa9ab-d621-4cd7-b7c8-793cdbab72f1"
      }
    },
    "owner": "sling0623"
  }
}
