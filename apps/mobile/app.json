{
  "expo": {
    "name": "Trailog",
    "slug": "trailog",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "trailog",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.sling.trailog",
      "supportsTablet": true
    },
    "android": {
      "package": "com.trailog.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Trailog가 사진을 업로드하기 위해 갤러리 접근이 필요합니다"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Trailog가 지도에 현재 위치를 표시하기 위해 위치 정보를 사용합니다"
        }
      ],
      [
        "@mj-studio/react-native-naver-map",
        {
          "client_id": "p3qy2ctdv1"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": ["https://repository.map.naver.com/archive/maven"]
          }
        }
      ],
      "expo-font",
      "expo-splash-screen",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a7aa9ab-d621-4cd7-b7c8-793cdbab72f1"
      }
    },
    "owner": "sling0623",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2a7aa9ab-d621-4cd7-b7c8-793cdbab72f1"
    }
  }
}
