# apps/server .env.example
#
# 백엔드(NestJS) 환경변수 가이드. cp .env.example .env 후 본인 값으로.
# 운영(Fly.io)에선 `fly secrets set KEY=VALUE`로 주입 — .env 사용 X.

# ─── 서버 기본 ───

# NestJS 서버 포트
PORT=3000

# ─── DB (Phase 2 4.2 도입) ───

# Postgres connection (TypeORM)
# 루트 .env의 POSTGRES_* 값과 일치시킬 것 (로컬 docker-compose Postgres)
DATABASE_URL=postgresql://trailog:trailog_dev_password@localhost:5432/trailog

# 부팅 시 미실행 마이그레이션 자동 적용 (운영 false 권장, 로컬 false 권장)
RUN_MIGRATIONS_ON_BOOT=false

# TypeORM SQL 로그 출력 (학습 단계엔 true 추천)
TYPEORM_LOGGING=true

# ─── Redis (Phase 2 4.4 BullMQ) ───
#
# 로컬: docker compose (pnpm db:up) — redis://localhost:6379
# 운영: Q11 결정 시점에 Upstash (무료 티어) 또는 Fly Redis 결정.
#       fly secrets set REDIS_URL=rediss://...
REDIS_URL=redis://localhost:6379

# ─── JWT 인증 (Phase 2 4.1) ───

# Secret 생성: 각 키마다 `openssl rand -hex 32` (256-bit = 64 hex chars)
# 두 secret을 별개로 둘 것 — 한 쪽 유출 시 다른 쪽 안전 + 키 회전 가능
# 운영(Fly.io)에선 `fly secrets set JWT_SECRET=$(openssl rand -hex 32)` 등으로 주입
JWT_SECRET=__REPLACE_WITH_openssl_rand_hex_32__
JWT_REFRESH_SECRET=__REPLACE_WITH_DIFFERENT_openssl_rand_hex_32__

# Access token 만료 — 짧게 (15분 권장). 노출 시 피해 최소화.
JWT_EXPIRES_IN=15m

# Refresh token 만료 — 길게 (7일 권장). 사용자 편의 (자동 재로그인).
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudflare R2 (Phase 2 4.3 도입) — 이미지 저장소 ───
#
# ADR-0007 참고. R2는 S3 호환 API — AWS SDK 그대로 사용.
# Account ID: Cloudflare 대시보드 우측 또는 R2 S3 API URL에서 추출 (32자 hex)
# Access Key / Secret: R2 → Manage R2 API Tokens → Create API Token 발급 시 받음
#                      Secret은 1회만 표시 — 즉시 비밀번호 매니저 또는 .env에 박을 것
# Bucket: dev(`trailog-photos-dev`) + prod(`trailog-photos-prod`, 운영 진입 시 생성)
#
# 운영(Fly.io)에선 다음으로 주입:
#   fly secrets set R2_ACCOUNT_ID=... R2_ACCESS_KEY_ID=... R2_SECRET_ACCESS_KEY=... R2_BUCKET_NAME=trailog-photos-prod
R2_ACCOUNT_ID=__YOUR_CLOUDFLARE_ACCOUNT_ID_32_HEX__
R2_ACCESS_KEY_ID=__YOUR_R2_ACCESS_KEY_ID__
R2_SECRET_ACCESS_KEY=__YOUR_R2_SECRET_ACCESS_KEY__
R2_BUCKET_NAME=trailog-photos-dev
