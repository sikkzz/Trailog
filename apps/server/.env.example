# apps/server .env.example
#
# 백엔드(NestJS) 환경변수 가이드. cp .env.example .env 후 본인 값으로.
# 운영(Fly.io)에선 `fly secrets set KEY=VALUE`로 주입 — .env 사용 X.

# ─── 서버 기본 ───

# NestJS 서버 포트
PORT=3000

# ─── DB (Phase 2 4.2 도입) ───

# Postgres connection (TypeORM)
# 루트 .env의 POSTGRES_* 값과 일치시킬 것 (로컬 docker-compose Postgres)
DATABASE_URL=postgresql://trailog:trailog_dev_password@localhost:5432/trailog

# 부팅 시 미실행 마이그레이션 자동 적용 (운영 false 권장, 로컬 false 권장)
RUN_MIGRATIONS_ON_BOOT=false

# TypeORM SQL 로그 출력 (학습 단계엔 true 추천)
TYPEORM_LOGGING=true

# ─── Phase 2 4.4 부터 사용 (미리 가이드) ───

# Redis connection (BullMQ)
# REDIS_URL=redis://localhost:6379

# ─── Phase 2 4.1 부터 사용 (인증, 다음 단계) ───

# JWT secret (랜덤 64자+ 권장: openssl rand -hex 32)
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
