# apps/server .env.example
#
# 백엔드(NestJS) 환경변수 가이드. cp .env.example .env 후 본인 값으로.
# 운영(Fly.io)에선 `fly secrets set KEY=VALUE`로 주입 — .env 사용 X.

# ─── 서버 기본 ───

# NestJS 서버 포트
PORT=3000

# ─── DB (Phase 2 4.2 도입) ───

# Postgres connection (TypeORM)
# 루트 .env의 POSTGRES_* 값과 일치시킬 것 (로컬 docker-compose Postgres)
DATABASE_URL=postgresql://trailog:trailog_dev_password@localhost:5432/trailog

# 부팅 시 미실행 마이그레이션 자동 적용 (운영 false 권장, 로컬 false 권장)
RUN_MIGRATIONS_ON_BOOT=false

# TypeORM SQL 로그 출력 (학습 단계엔 true 추천)
TYPEORM_LOGGING=true

# ─── Phase 2 4.4 부터 사용 (미리 가이드) ───

# Redis connection (BullMQ)
# REDIS_URL=redis://localhost:6379

# ─── JWT 인증 (Phase 2 4.1) ───

# Secret 생성: 각 키마다 `openssl rand -hex 32` (256-bit = 64 hex chars)
# 두 secret을 별개로 둘 것 — 한 쪽 유출 시 다른 쪽 안전 + 키 회전 가능
# 운영(Fly.io)에선 `fly secrets set JWT_SECRET=$(openssl rand -hex 32)` 등으로 주입
JWT_SECRET=__REPLACE_WITH_openssl_rand_hex_32__
JWT_REFRESH_SECRET=__REPLACE_WITH_DIFFERENT_openssl_rand_hex_32__

# Access token 만료 — 짧게 (15분 권장). 노출 시 피해 최소화.
JWT_EXPIRES_IN=15m

# Refresh token 만료 — 길게 (7일 권장). 사용자 편의 (자동 재로그인).
JWT_REFRESH_EXPIRES_IN=7d
