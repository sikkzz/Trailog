# Trailog server .dockerignore
# Dockerfile은 루트에서 빌드하므로 모노레포 전체 기준 ignore 패턴.

# 의존성 (이미지에 안 들어감, builder가 fresh install)
**/node_modules
**/.pnpm-store

# 빌드 산출물 (이미지 안에서 새로 빌드)
**/dist
**/build
**/.next
**/.turbo

# 환경변수 (시크릿은 fly secrets로 주입)
**/.env
**/.env.local
**/.env.*.local

# 로그
**/*.log

# OS / IDE
.DS_Store
.vscode
.idea

# Git
.git
.gitignore
.github

# 문서/테스트 (production 이미지에 불필요)
docs
**/*.md
**/*.spec.ts
**/*.test.ts
**/__tests__

# Mobile (백엔드 이미지에 불필요)
apps/mobile

# Husky / CI 설정
.husky
.github

# Docker
**/Dockerfile
**/.dockerignore

# Misc
coverage
.expo
.expo-shared
