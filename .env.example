# Trailog 환경변수 예시 파일
# 사용법: 이 파일을 복사해서 .env 만들기 — `cp .env.example .env`
# .env 는 git에 안 올라감 (.gitignore 처리). 개인 머신마다 다른 값 가능.

# ── Database (PostgreSQL + PostGIS) ──
POSTGRES_USER=trailog
POSTGRES_PASSWORD=trailog_dev_password
POSTGRES_DB=trailog
POSTGRES_PORT=5432

# ── Cache / Queue (Redis) ──
REDIS_PORT=6379

# ── Server (apps/server) ──
# 백엔드가 DB에 접속할 때 쓰는 connection string.
# Docker compose가 띄운 컨테이너는 호스트 머신의 localhost에서 접근 가능.
DATABASE_URL=postgresql://trailog:trailog_dev_password@localhost:5432/trailog
REDIS_URL=redis://localhost:6379
PORT=3000
